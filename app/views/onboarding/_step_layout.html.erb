<% content_for :title, t('onboarding.nav_title', default: 'Onboarding') %>
<div class="onboarding-step" data-step="<%= step_number %>">
  <%# Progress bar %>
  <div class="onboarding-progress">
    <div class="onboarding-progress__bar">
      <div class="onboarding-progress__fill" style="width: <%= progress %>%"></div>
    </div>
    <span class="onboarding-progress__text">
      <%= t('onboarding.step_of', step: step_number, total: total_steps) %>
    </span>
  </div>

  <%# Back button %>
  <div class="onboarding-step__nav">
    <% if step_number > 1 %>
      <% prev_step = OnboardingController::STEPS[step_number - 2] %>
      <%= link_to onboarding_step_path(step_name: prev_step, from: @from), class: 'onboarding-back' do %>
        <i class="bi bi-arrow-left"></i>
        <%= t('common.back') %>
      <% end %>
    <% else %>
      <%= link_to onboarding_welcome_path, class: 'onboarding-back' do %>
        <i class="bi bi-arrow-left"></i>
        <%= t('common.back') %>
      <% end %>
    <% end %>
  </div>

  <%# Content %>
  <div class="onboarding-step__content">
    <h1 class="onboarding-step__title"><%= title %></h1>
    <p class="onboarding-step__subtitle"><%= subtitle %></p>

    <%= yield %>
  </div>
</div>

<script data-turbo-step="<%= step_number %>">
(function() {
  function validateOnboardingForm() {
    var form = document.querySelector('.onboarding-form');
    if (!form) return;

    var submitBtn = form.querySelector('.onboarding-submit');
    if (!submitBtn) return;

    function checkValidity() {
      var toggle = form.querySelector('#toggleField');
      var numberInput = form.querySelector('input[type="number"][name="value"]');
      var radioInputs = form.querySelectorAll('input[type="radio"][name="value"]');

      // Case 1: Toggle (Sí/No) steps
      if (toggle) {
        if (!toggle.value) { submitBtn.disabled = true; return; }
        if (toggle.value === 'no') { submitBtn.disabled = false; return; }
        // toggle === 'yes': check the conditional amount field
        if (numberInput && (!numberInput.value || Number(numberInput.value) <= 0)) {
          submitBtn.disabled = true; return;
        }
        submitBtn.disabled = false;
        return;
      }

      // Case 2: Radio card steps (riesgo)
      if (radioInputs.length > 0) {
        var anyChecked = Array.prototype.some.call(radioInputs, function(r) { return r.checked; });
        submitBtn.disabled = !anyChecked;
        return;
      }

      // Case 3: Simple number input steps
      if (numberInput) {
        submitBtn.disabled = !numberInput.value || Number(numberInput.value) <= 0;
        return;
      }
    }

    // Initial state
    checkValidity();

    // Listen to all relevant events (toggle scripts dispatch 'change' on #toggleField)
    form.addEventListener('input', checkValidity);
    form.addEventListener('change', checkValidity);
  }

  document.addEventListener('turbo:load', validateOnboardingForm);
  if (document.readyState !== 'loading') { validateOnboardingForm(); }
  else { document.addEventListener('DOMContentLoaded', validateOnboardingForm); }
})();
</script>
